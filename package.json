{
  "name": "heading-audit",
  "version": "1.0.0",
  "description": "CLI and HTTP API for auditing heading structure and semantic nesting in HTML pages.",
  "main": "dist/index.js",
  "bin": {
    "heading-audit": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "TODO.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "cli": "node dist/cli.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "accessibility",
    "seo",
    "html",
    "audit",
    "headings",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walidhanifi/heading-audit.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/walidhanifi/heading-audit/issues"
  },
  "homepage": "https://github.com/walidhanifi/heading-audit#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "type": "module",
  "dependencies": {
    "cheerio": "^1.2.0",
    "express": "^5.2.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
